# Monorepo companion projects: keep source, ignore generated dependencies.
node_modules/
client/node_modules/
client/.vite/
server/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local environment files.
.env
.env.*
server/.env

