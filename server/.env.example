# Copy to .env and fill in. Keep .env out of git (see .gitignore).

# --- Database (giữ nguyên MySQL hiện có) ---
# Production RMIT:
DB_HOST=talsprddb02.int.its.rmit.edu.au
DB_PORT=3306
DB_NAME=COSC3046_2502_G20
DB_USER=COSC3046_2502_G20
DB_PASSWORD=

# Local XAMPP thay thế (bỏ comment để dùng):
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_NAME=test
# DB_USER=root
# DB_PASSWORD=

# --- Server ---
PORT=3000
# Bí mật ký session cookie — đổi thành chuỗi ngẫu nhiên dài.
SESSION_SECRET=change-me-to-a-long-random-string
# Origin của client Vue (dev). Dùng cho CORS khi không qua Vite proxy.
CLIENT_ORIGIN=http://localhost:5173
# true khi chạy production sau HTTPS
COOKIE_SECURE=false

# --- Sign in with Google (OAuth 2.0) ---
# Web-application OAuth client from Google Cloud Console. Register the callback
# .../api/auth/google/callback as an Authorized redirect URI for BOTH local and
# production. Leave blank to hide the Google buttons (graceful degradation).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional explicit callback URI. Recommended in dev: the API runs on :3000 while
# the Vue client is on :5173. If unset it is derived from the request host.
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# --- AI Coach ---
# Provider: "gemini" (Google Generative Language API) hoặc "openrouter" (OpenAI-compatible).
AI_PROVIDER=gemini
AI_COACH_DAILY_LIMIT=20
AI_COACH_HISTORY_TURNS=10
# Gemini
GEMINI_API_KEY=
AI_COACH_MODEL=gemini-3.1-flash-lite
# OpenRouter (dùng khi AI_PROVIDER=openrouter)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-31b-it:free
