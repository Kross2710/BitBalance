#!/usr/bin/env bash
#
# BitBalance pre-commit hook — block PHP 7.4 "prod landmines" from being committed.
#
# Runs scripts/php74-lint.php over the *staged* .php files only (fast). If any
# landmine is found the commit is refused. Install once with:
#
#     ./scripts/install-hooks.sh
#
# Bypass for a single commit (use sparingly):  git commit --no-verify
#
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"

# Collect staged PHP files (Added / Copied / Modified), NUL-delimited for safety.
# Read with a portable loop (no mapfile — macOS ships bash 3.2).
FILES=()
while IFS= read -r -d '' f; do
  FILES+=("$ROOT/$f")
done < <(git diff --cached --name-only --diff-filter=ACM -z -- '*.php')

if [ ${#FILES[@]} -eq 0 ]; then
  exit 0
fi

# Prefer the XAMPP PHP binary (matches the dev environment), else fall back to PATH.
PHP_BIN=""
for cand in /Applications/XAMPP/xamppfiles/bin/php php php8 php7; do
  if command -v "$cand" >/dev/null 2>&1; then
    PHP_BIN="$cand"
    break
  fi
done
if [ -z "$PHP_BIN" ]; then
  echo "pre-commit: no php binary found — skipping PHP 7.4 lint." >&2
  exit 0
fi

if ! "$PHP_BIN" "$ROOT/scripts/php74-lint.php" "${FILES[@]}"; then
  echo ""
  echo "Commit blocked: staged PHP would fatal on RMIT (PHP 7.4.33)."
  echo "Fix the lines above, or bypass once with:  git commit --no-verify"
  exit 1
fi

exit 0
